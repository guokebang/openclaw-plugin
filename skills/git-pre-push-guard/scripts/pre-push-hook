#!/usr/bin/env bash
# Git Pre-Push Hook - 敏感信息检测
# 位置：.git/hooks/pre-push
# 作用：在每次 git push 前自动检测敏感信息，即使 AI 绕过 Skill 也会被拦截

set -euo pipefail

# 获取脚本所在目录的上级目录（即项目根目录的 scripts/）
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"
CHECK_SCRIPT="$SCRIPT_DIR/check_secrets.py"

# 如果检测脚本不存在，跳过检查
if [[ ! -f "$CHECK_SCRIPT" ]]; then
  echo "⚠️  未找到敏感信息检测脚本，跳过检查"
  echo "   提示：将 check_secrets.py 放在项目根目录的 scripts/ 文件夹中"
  exit 0
fi

echo "🛡️  执行推送前敏感信息检查..."

# 检查 git diff
HAS_STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | head -1)

if [[ -z "$HAS_STAGED" ]]; then
  echo "ℹ️  没有 staged 内容，跳过检查"
  exit 0
fi

# 运行检测脚本
python3 "$CHECK_SCRIPT" --staged --commits 3 --min-risk MEDIUM 2>&1
RESULT=$?

if [[ $RESULT -eq 0 ]]; then
  echo "✅ 未发现敏感信息，允许推送"
  exit 0
else
  echo ""
  echo "══════════════════════════════════════════════"
  echo "  ⛔ 推送已阻止：发现敏感信息"
  echo "══════════════════════════════════════════════"
  echo ""
  echo "如需强制推送（不推荐），请执行："
  echo "  git push --no-verify"
  echo ""
  echo "建议操作："
  echo "  1. 使用 .gitignore 排除敏感文件"
  echo "  2. 使用环境变量代替硬编码密钥"
  echo "  3. 使用 git-crypt 或 SOPS 加密敏感文件"
  echo "  4. 使用 git-filter-repo 清理历史提交"
  exit 1
fi
